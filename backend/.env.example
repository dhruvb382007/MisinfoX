# Database configuration
# For local development, sqlite:///./local.db is used by default if DATABASE_URL is not set.
# For production, provide a PostgreSQL connection string (e.g. Supabase).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@YOUR_DATABASE_HOST:5432/postgres

# Encryption key for securing user API keys (must be a base64-encoded 32-byte key)
# You can generate one in Python using:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-base64-32byte-fernet-key-here

# Secret key for signing JWT auth tokens
JWT_SECRET_KEY=your-secure-jwt-secret-key-here
